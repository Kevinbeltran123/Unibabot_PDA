

# PDAs reales (datos confidenciales de la universidad)
PDAs/

# Base vectorial de ChromaDB (se regenera con: python src/rag/ingest.py)
data/chroma_db/

# Pares crudos sin output (intermedio de trabajo)
data/pares_crudos.jsonl

# Modelos entrenados (pesados, se generan en Colab)
models/
*.pt
*.pth
*.bin
*.safetensors
*.gguf
*.onnx

# Reportes JSON generados (se regeneran corriendo el agente)
# Pero los .md del reporte de evaluacion SI van al repo
results/*.json
results/history/*.json
!results/evaluation_report.md
!results/history/.gitkeep

# Archivos temporales de la webapp (PDFs subidos)
tmp/

# Cache de enrichment LLM (resumenes y correcciones enriquecidas)
# Se regenera al primer uso. Mantiene reproducibilidad bit-a-bit por PDA.
cache/

