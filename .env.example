# UnibaBot PDA API - copia a .env y ajusta

# Base de datos: SQLite por defecto en data/unibabot.db
# DATABASE_URL=sqlite:///./data/unibabot.db

# Redis para la cola RQ
REDIS_URL=redis://localhost:6379/0

# JWT - generar con: openssl rand -hex 32
JWT_SECRET=cambiame-en-produccion-con-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=1440

# CORS - lista separada por comas
CORS_ORIGINS=http://localhost:3000

# Limite upload PDF en MB
MAX_UPLOAD_MB=20

# Modo sincrono: si es 1, NO usa RQ y corre el analisis dentro del request.
# Util para desarrollo sin Redis. NO usar en produccion (bloquea workers HTTP).
SYNC_MODE=0
